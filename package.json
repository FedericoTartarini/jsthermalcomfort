{
  "name": "jsthermalcomfort",
  "version": "0.2.1",
  "description": "A JavaScript package to calculate thermophysiological, thermal comfort, thermal stress indices",
  "type": "module",
  "files": [
    "lib"
  ],
  "main": "./lib/esm/index.js",
  "types": "./lib/esm/types/index.d.ts",
  "scripts": {
    "clean": "rm -rf ./lib",
    "build": "npm run clean && npm run build:esm && npm run build:cjs",
    "build:esm": "tsc -p ./configs/tsconfig.esm.json",
    "build:cjs": "tsc -p ./configs/tsconfig.cjs.json",
    "test": "node --experimental-vm-modules ./node_modules/.bin/jest",
    "semantic-release": "semantic-release",
    "docs": "npx documentation build ./src/index.js -f html --github --config documentation.yml -a public --theme docs_theme/index.js -o docs && ./create_readme.sh",
    "format": "npx prettier . --write",
    "check:format": "npx prettier . --check"
  },
  "release": {
    "branches": [
      "main"
    ]
  },
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/FedericoTartarini/jsthermalcomfort.git"
  },
  "engines": {
    "node": ">=20"
  },
  "keywords": [
    "thermal comfort",
    "heat stress",
    "predicted mean vote",
    "human thermophysiological modeling"
  ],
  "author": "Federico Tartarini",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/FedericoTartarini/jsthermalcomfort/issues"
  },
  "homepage": "https://federicotartarini.github.io/jsthermalcomfort/",
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@jest/globals": "^29.7.0",
    "@tailwindcss/postcss": "^4.2.1",
    "@tailwindcss/vite": "^4.2.1",
    "@types/jest": "^30.0.0",
    "@typescript-eslint/eslint-plugin": "^8.57.0",
    "@typescript-eslint/parser": "^8.57.0",
    "autoprefixer": "^10.4.27",
    "documentation": "^14.0.3",
    "eslint": "^10.0.3",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-svelte": "^3.15.2",
    "flowbite": "^4.0.1",
    "flowbite-svelte": "^1.31.0",
    "github-slugger": "^2.0.0",
    "globals": "^17.4.0",
    "highlight.js": "^11.11.1",
    "jest": "^29.7.0",
    "jsdoc": "^4.0.5",
    "lodash": "^4.17.23",
    "postcss": "^8.5.8",
    "prettier": "^3.8.1",
    "prettier-plugin-svelte": "^3.5.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "svelte": "^5.53.11",
    "svelte-eslint-parser": "^1.6.0",
    "tailwindcss": "^4.2.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.0"
  },
  "dependencies": {
    "mathjs": "^11.12.0",
    "node-fetch": "^3.3.2"
  }
}
